{
  "name": "lasts-player",
  "version": "1.9.0",
  "description": "Dark music player",
  "main": "./src/main.js",
  "type": "commonjs",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.musicplayer.app",
    "productName": "lasts player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "./assets/favicon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "ffmpeg-static": "^5.3.0",
    "howler": "^2.2.4",
    "music-metadata": "^7.14.0",
    "node-id3": "^0.2.9",
    "yt-dlp-exec": "^1.0.2"
  }
}
