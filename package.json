{
  "name": "lasts-player",
  "version": "1.7.0",
  "description": "Dark music player",
  "main": "./src/main.js",
  "type": "commonjs",

  "author": "",
  "license": "ISC",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "build": {
    "appId": "com.musicplayer.app",
    "productName": "lasts player",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*"
    ],

    "win": {
      "target": "nsis",
      "icon": "./assets/favicon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },

  "dependencies": {
    "@electron/remote": "^2.1.3",
    "howler": "^2.2.4",
    "music-metadata": "^7.14.0"
  }
}